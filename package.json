{
  "name": "petcare-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:admin": "pnpm --filter @petcare/admin dev",
    "dev:miniapp": "pnpm --filter @petcare/miniapp dev:h5",
    "dev:api": "pnpm --filter @petcare/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:api": "node scripts/run-api-tests.mjs",
    "test:api:coverage": "node scripts/run-api-tests.mjs --coverage",
    "docker:build": "docker compose --profile app build",
    "docker:up": "docker compose --profile app up -d",
    "docker:down": "docker compose --profile app down",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
