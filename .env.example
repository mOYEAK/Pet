NODE_ENV=development

DATABASE_URL="postgresql://petcare:petcare@localhost:5432/petcare?schema=public"
REDIS_URL="redis://localhost:6379"

API_PORT=3000
VITE_API_BASE_URL="http://localhost:3000/api"

# In-app reminders for confirmed bookings within the configured time window.
BOOKING_REMINDER_ENABLED="true"
BOOKING_REMINDER_HOURS="24"

# Optional OpenAI-compatible provider. Keep disabled for the local rule fallback.
AI_ENABLED="false"
AI_API_KEY=""
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4.1-mini"
