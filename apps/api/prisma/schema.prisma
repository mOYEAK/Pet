generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum PetType {
  CAT
  DOG
  OTHER
}

enum PetGender {
  MALE
  FEMALE
  UNKNOWN
}

enum SizeType {
  SMALL
  MEDIUM
  LARGE
  UNKNOWN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  SERVING
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PackageCardStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

enum UserCouponStatus {
  UNUSED
  USED
  EXPIRED
  DISABLED
}

enum RechargePayMethod {
  CASH
  WECHAT
  ALIPAY
  MOCK_PAY
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  MEMBERSHIP_RECHARGED
  PACKAGE_CARD_ISSUED
  ORDER_PAID
}

model User {
  id                 String              @id @default(cuid())
  nickname           String?
  phone              String?             @unique
  avatar             String?
  role               UserRole            @default(CUSTOMER)
  pets               Pet[]
  bookings           Booking[]
  orders             Order[]
  membership         Membership?
  packageCards       PackageCard[]
  userCoupons        UserCoupon[]
  consumptionRecords ConsumptionRecord[]
  rechargeRecords    RechargeRecord[]
  followUpTasks      FollowUpTask[]
  aiConversations    AiConversation[]
  notifications      Notification[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@map("users")
}

model Pet {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  name       String
  type       PetType
  breed      String?
  gender     PetGender @default(UNKNOWN)
  age        Decimal?  @db.Decimal(4, 1)
  weight     Decimal?  @db.Decimal(5, 2)
  isNeutered Boolean   @default(false) @map("is_neutered")
  notes      String?
  user       User      @relation(fields: [userId], references: [id])
  bookings   Booking[]
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("pets")
}

model Service {
  id              String        @id @default(cuid())
  name            String
  category        String
  petType         PetType       @map("pet_type")
  sizeType        SizeType      @default(UNKNOWN) @map("size_type")
  basePrice       Decimal       @map("base_price") @db.Decimal(10, 2)
  durationMinutes Int           @map("duration_minutes")
  description     String?
  notice          String?
  enabled         Boolean       @default(true)
  bookings        Booking[]
  packageCards    PackageCard[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([petType, sizeType, enabled])
  @@map("services")
}

model Booking {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  petId          String        @map("pet_id")
  serviceId      String        @map("service_id")
  bookingDate    DateTime      @map("booking_date") @db.Date
  startTime      DateTime      @map("start_time")
  endTime        DateTime      @map("end_time")
  status         BookingStatus @default(PENDING)
  remark         String?
  reminderSentAt DateTime?     @map("reminder_sent_at")
  user           User          @relation(fields: [userId], references: [id])
  pet            Pet           @relation(fields: [petId], references: [id])
  service        Service       @relation(fields: [serviceId], references: [id])
  order          Order?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([bookingDate, startTime, endTime])
  @@index([status])
  @@index([status, startTime, reminderSentAt])
  @@map("bookings")
}

model Order {
  id                 String              @id @default(cuid())
  bookingId          String              @unique @map("booking_id")
  userId             String              @map("user_id")
  couponId           String?             @unique @map("coupon_id")
  totalAmount        Decimal             @map("total_amount") @db.Decimal(10, 2)
  discountAmount     Decimal             @default(0) @map("discount_amount") @db.Decimal(10, 2)
  paidAmount         Decimal             @default(0) @map("paid_amount") @db.Decimal(10, 2)
  payMethod          String?             @map("pay_method")
  status             OrderStatus         @default(PENDING_PAYMENT)
  paidAt             DateTime?           @map("paid_at")
  booking            Booking             @relation(fields: [bookingId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  coupon             UserCoupon?         @relation("OrderCoupon", fields: [couponId], references: [id])
  consumptionRecords ConsumptionRecord[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([status, paidAt])
  @@map("orders")
}

model CouponTemplate {
  id              String       @id @default(cuid())
  name            String
  thresholdAmount Decimal      @map("threshold_amount") @db.Decimal(10, 2)
  discountAmount  Decimal      @map("discount_amount") @db.Decimal(10, 2)
  startDate       DateTime?    @map("start_date") @db.Date
  endDate         DateTime?    @map("end_date") @db.Date
  description     String?
  enabled         Boolean      @default(true)
  userCoupons     UserCoupon[]
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([enabled, endDate])
  @@map("coupon_templates")
}

model UserCoupon {
  id         String           @id @default(cuid())
  templateId String           @map("template_id")
  userId     String           @map("user_id")
  status     UserCouponStatus @default(UNUSED)
  usedOrder  Order?           @relation("OrderCoupon")
  usedAt     DateTime?        @map("used_at")
  template   CouponTemplate   @relation(fields: [templateId], references: [id])
  user       User             @relation(fields: [userId], references: [id])
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([templateId])
  @@map("user_coupons")
}

model Membership {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  level     String   @default("standard")
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  points    Int      @default(0)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("memberships")
}

model PackageCard {
  id             String            @id @default(cuid())
  userId         String            @map("user_id")
  serviceId      String            @map("service_id")
  totalTimes     Int               @map("total_times")
  remainingTimes Int               @map("remaining_times")
  expireDate     DateTime?         @map("expire_date") @db.Date
  status         PackageCardStatus @default(ACTIVE)
  user           User              @relation(fields: [userId], references: [id])
  service        Service           @relation(fields: [serviceId], references: [id])
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("package_cards")
}

model ConsumptionRecord {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  orderId     String?  @map("order_id")
  amount      Decimal  @db.Decimal(10, 2)
  type        String
  description String?
  user        User     @relation(fields: [userId], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("consumption_records")
}

model RechargeRecord {
  id             String            @id @default(cuid())
  userId         String            @map("user_id")
  paidAmount     Decimal           @map("paid_amount") @db.Decimal(10, 2)
  bonusAmount    Decimal           @default(0) @map("bonus_amount") @db.Decimal(10, 2)
  creditedAmount Decimal           @map("credited_amount") @db.Decimal(10, 2)
  balanceBefore  Decimal           @map("balance_before") @db.Decimal(10, 2)
  balanceAfter   Decimal           @map("balance_after") @db.Decimal(10, 2)
  payMethod      RechargePayMethod @map("pay_method")
  remark         String?
  user           User              @relation(fields: [userId], references: [id])
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([payMethod, createdAt])
  @@map("recharge_records")
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  embedding Json?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([enabled, category])
  @@map("knowledge_base")
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  channel   String
  role      String
  content   String
  toolCalls Json?    @map("tool_calls")
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("ai_conversations")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  title       String
  content     String
  type        NotificationType
  relatedType String?          @map("related_type")
  relatedId   String?          @map("related_id")
  readAt      DateTime?        @map("read_at")
  user        User             @relation(fields: [userId], references: [id])
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([userId, readAt, createdAt])
  @@index([type, createdAt])
  @@map("notifications")
}

model FollowUpTask {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String
  content   String?
  status    String    @default("pending")
  dueDate   DateTime? @map("due_date") @db.Date
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status, dueDate])
  @@map("follow_up_tasks")
}
