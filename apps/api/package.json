{
  "name": "@petcare/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @petcare/shared build && pnpm --filter @petcare/agent build && nest start --watch",
    "build": "pnpm --filter @petcare/shared build && pnpm --filter @petcare/agent build && nest build",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "typecheck": "pnpm --filter @petcare/shared build && pnpm --filter @petcare/agent build && tsc --noEmit",
    "test:e2e:prepare": "dotenv -e .env.test -- prisma migrate deploy",
    "test:e2e": "pnpm --filter @petcare/shared build && pnpm --filter @petcare/agent build && node node_modules/jest/bin/jest.js --config test/jest-e2e.json --runInBand",
    "test:e2e:coverage": "pnpm --filter @petcare/shared build && pnpm --filter @petcare/agent build && node node_modules/jest/bin/jest.js --config test/jest-e2e.json --runInBand --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/schedule": "6.1.3",
    "@petcare/agent": "workspace:*",
    "@petcare/shared": "workspace:*",
    "@prisma/client": "^6.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.3",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^8.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.9.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
